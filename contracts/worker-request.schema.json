{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storpt.local/contracts/worker-request.schema.json",
  "title": "StoRpt Excel Worker request",
  "type": "object",
  "additionalProperties": false,
  "required": ["inputPath", "outputPath", "format", "sheetIndex", "latestPeriod", "changes"],
  "properties": {
    "inputPath": { "type": "string", "minLength": 1 },
    "outputPath": { "type": "string", "minLength": 1 },
    "format": { "type": "string", "enum": ["xls", "xlsx"] },
    "sheetIndex": { "type": "integer", "minimum": 0 },
    "latestPeriod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["titleRow", "dataStartRow"],
      "properties": {
        "titleRow": { "type": "integer", "minimum": 0 },
        "dataStartRow": { "type": "integer", "minimum": 0 }
      }
    },
    "changes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startDate", "endDate", "codes", "fillName", "fillIdealBuy", "fillIdealSell"],
      "properties": {
        "startDate": { "type": "string", "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}$" },
        "endDate": { "type": "string", "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}$" },
        "codes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[0-9]{6}$" }
        },
        "fillName": { "type": "boolean" },
        "fillIdealBuy": { "type": "boolean" },
        "fillIdealSell": { "type": "boolean" }
      }
    }
  }
}
